{
  "id": null,
  "uid": "bootcamp-api-observabilidad",
  "title": "Bootcamp API - Observabilidad Base",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "API UP",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PROMETHEUS_DS" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"dotnet-api\"}",
          "legendFormat": "up"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Req/s",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PROMETHEUS_DS" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_received_total[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latencia (s)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PROMETHEUS_DS" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Errores 5xx/s",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PROMETHEUS_DS" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_received_total{code=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests por endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PROMETHEUS_DS" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method, controller, action, code) (rate(http_requests_received_total[1m]))",
          "legendFormat": "{{method}} {{controller}}/{{action}} {{code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latencia p95 por endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PROMETHEUS_DS" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, method, controller, action) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{method}} {{controller}}/{{action}}"
        }
      ]
    }
  ]
}
